# ============================================================
# Math AI Agent Pipeline — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- LLM Provider (Groq) ---
GROQ_API_KEY=gsk_your_groq_api_key_here
# Model for reasoning/solving (placeholder — team will decide)
LLM_MODEL_REASONING=PLACEHOLDER_REASONING_MODEL_ID
# Model for extraction/OCR (placeholder — faster model preferred)
LLM_MODEL_EXTRACTION=PLACEHOLDER_EXTRACTION_MODEL_ID
# Model for classification (placeholder — lightweight model)
LLM_MODEL_CLASSIFIER=PLACEHOLDER_CLASSIFIER_MODEL_ID

# --- Wolfram Alpha ---
WOLFRAM_ALPHA_APP_ID=your_wolfram_app_id_here

# --- Tavily Search ---
TAVILY_API_KEY=tvly-your_tavily_key_here

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_CACHE_TTL_SECONDS=86400

# --- Database (SQLite) ---
DATABASE_URL=sqlite+aiosqlite:///./data/math_agent.db

# --- LangSmith Tracing ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__your_langsmith_key_here
LANGCHAIN_PROJECT=math-ai-agent

# --- Application ---
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
MAX_PARALLEL_PROBLEMS=5
MAX_UPLOAD_SIZE_MB=10
PYTHON_SANDBOX_TIMEOUT_SECONDS=5
PYTHON_SANDBOX_MAX_RETRIES=3
WOLFRAM_TIMEOUT_SECONDS=10
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- HuggingFace Spaces ---
HF_SPACE=true
