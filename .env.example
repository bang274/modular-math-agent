# ============================================================
# Math AI Agent Pipeline — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- LLM Provider (Groq) ---
GROQ_API_KEY=gsk_your_groq_api_key_here
# Model for OCR and extraction (prefers vision models)
LLM_MODEL_EXTRACTOR=meta-llama/llama-4-scout-17b-16e-instruct
# Model for planning and tool calling (prefers logical models)
LLM_MODEL_PLANNER=moonshotai/kimi-k2-instruct-0905
# Model for python code generation
LLM_MODEL_CODER=qwen/qwen3-32b
# Model for python code debugging/fixing
LLM_MODEL_FIXER=openai/gpt-oss-20b
# Model for final aggregation and reasoning (prefers smart reasoning models)
LLM_MODEL_AGGREGATOR=openai/gpt-oss-120b



# --- Wolfram Alpha ---
WOLFRAM_ALPHA_APP_ID=your_wolfram_app_id_here

# --- Tavily Search ---
TAVILY_API_KEY=tvly-your_tavily_key_here

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_CACHE_TTL_SECONDS=86400

# --- Database (SQLite) ---
DATABASE_URL=sqlite+aiosqlite:///./data/math_agent.db

# --- LangSmith Tracing ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__your_langsmith_key_here
LANGCHAIN_PROJECT=math-ai-agent

# --- Application ---
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
MAX_PARALLEL_PROBLEMS=5
MAX_UPLOAD_SIZE_MB=10
PYTHON_SANDBOX_TIMEOUT_SECONDS=5
PYTHON_SANDBOX_MAX_RETRIES=3
WOLFRAM_TIMEOUT_SECONDS=10
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- HuggingFace Spaces ---
HF_SPACE=true
